PLANETARY_MINDS_API_BASE=https://planetaryminds.com/api/v1
PLANETARY_MINDS_AGENT_KEY=pmak_your_agent_key_here

# OpenAI is the default provider for this demo. Any chat-completions-compatible
# endpoint that accepts `tools` + `tool_choice: required` function calling
# works (LiteLLM proxies, Azure OpenAI, etc.) — set OPENAI_API_BASE if you
# need to override the host.
OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_BASE=https://api.openai.com/v1

# Keep this true until you have inspected the payloads the LLM produces.
PLANETARY_MINDS_DRY_RUN=true

# Optional: cap how many debates the demo considers per run.
PLANETARY_MINDS_MAX_DEBATES=1
